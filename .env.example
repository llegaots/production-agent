# Copy to .env and fill in values from your Supabase project dashboard.
# Project Settings → API: URL + service_role key (server-side only — never expose to browsers).
# Project Settings → Database → Connection string → URI (direct connection, not pooler, for migrations/CLI).

# PRODUCTION AGENT project (ref: awwcdqwdwrtbmkplpkup)
SUPABASE_URL=https://awwcdqwdwrtbmkplpkup.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.awwcdqwdwrtbmkplpkup.supabase.co:5432/postgres

LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_QA_MODEL=claude-sonnet-4-20250514
QA_MAX_CASES=1
QA_MAX_ITERATIONS=2
QA_TARGET_TEST_JOBS=20
QA_MIN_TEST_JOBS=15
QA_MAX_TEST_JOBS=25
GOOGLE_MAPS_API_KEY=
TOMORROW_IO_API_KEY=
CURSOR_API_KEY=
CURSOR_AUTO_HANDOFF=false
CURSOR_HANDOFF_MODEL=claude-sonnet-4-20250514

MAX_CRITIC_ITERATIONS=4
OPTIMIZER_TIME_LIMIT_SECONDS=30
DEFAULT_TIMEZONE=America/Toronto

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# Optional — browser Supabase anon key (falls back to SUPABASE_SERVICE_KEY in dev)
# SUPABASE_ANON_KEY=
