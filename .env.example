# --- LLM: Claude agents (recommended) ---
# Copy this file to `.env` in the project root (same folder as run.sh).
#
# Anthropic Claude powers agent narratives, client messages, and address refinement.
# Get a key: https://console.anthropic.com/
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6
# Use dashes, not dots. Anthropic 4.6+ IDs: claude-sonnet-4-6 / claude-opus-4-7 / claude-haiku-4-5-20251001
# Friendly aliases auto-normalized: "claude-sonnet-4.6" → claude-sonnet-4-6, "sonnet" → claude-sonnet-4-6
# Cheaper/faster: claude-haiku-4-5-20251001 (~10x cheaper than Sonnet, fine for QA case design)

# --- Optional: OpenAI instead of Claude ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# --- Google Geocoding (recommended for accurate routing) ---
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Optional: West Island service area (defaults: Sainte-Anne depot, 45 km radius)
# SERVICE_AREA_LAT=45.4030
# SERVICE_AREA_LNG=-73.9470
# SERVICE_AREA_RADIUS_KM=45

# --- Supabase (optional) ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here

# --- Cursor Cloud Agents (auto-fix after QA) ---
# Create key: Cursor Dashboard → Cloud Agents (not the generic dashboard key)
# After POST /api/qa/run, ProductionAgent launches a cloud agent with the handoff report.
CURSOR_API_KEY=crsr_f47ad0eb9512527b766a483caa7c18c39fcc97fbd5dac939356f3cb450265b78
# Optional — auto-detected from `git remote get-url origin` when omitted:
# CURSOR_REPOSITORY=https://github.com/your-org/production-agent
# CURSOR_REF=cursor/multiagent-production-scheduler-56d7
CURSOR_AUTO_HANDOFF=true
# CURSOR_AUTO_HANDOFF_ON_FAIL_ONLY=true
# CURSOR_AUTO_CREATE_PR=true
# CURSOR_API_VERSION=v1
CURSOR_HANDOFF_MODEL=claude-sonnet-4-6
# Defaults so the auto-fix agent does NOT use Opus 4.7 (~10x cost).
# Other Cursor Cloud options (GET https://api.cursor.com/v1/models for the live list):
#   composer-2.5 (Cursor's proprietary, ~$0.50/$2.50 per 1M tokens — cheapest)
#   claude-haiku-4-5         (fast, cheap Claude)
#   claude-opus-4-7          (most capable, most expensive)
#   gpt-5.5, gpt-5.3-codex, gemini-3.1-pro

# --- AI QA loop (default POST /api/qa/run mode=ai) ---
QA_MAX_CASES=1
QA_MAX_ITERATIONS=2
# Optional: separate (cheaper) model just for AI QA, leaves your main agents on Sonnet.
# Recommended while iterating with limited tokens — Haiku 4.5 is ~10x cheaper than Sonnet.
ANTHROPIC_QA_MODEL=claude-haiku-4-5-20251001
