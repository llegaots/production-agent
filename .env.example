# Copy to .env and fill in values from your Supabase project dashboard.
# Project Settings → API: URL + service_role key (server-side only — never expose to browsers).
# Project Settings → Database → Connection string → URI (direct connection, not pooler, for migrations/CLI).

# PRODUCTION AGENT project (ref: awwcdqwdwrtbmkplpkup)
SUPABASE_URL=https://awwcdqwdwrtbmkplpkup.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.awwcdqwdwrtbmkplpkup.supabase.co:5432/postgres

# Optional — used in later phases (set in .env only, never real values here)
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
GOOGLE_MAPS_API_KEY=
