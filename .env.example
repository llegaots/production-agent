# --- LLM (optional) ---
# If unset, agents fall back to deterministic rule-based reasoning and
# templated client messages. Setting this enables LLM-authored narrative
# rationales and client communications.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Supabase (optional) ---
# If both are set, the app hydrates clients/crews/equipment/jobs from
# Supabase on startup and persists every plan, message, plan review, and
# agent event back to the database for auditing and replay.
#
# Use the SERVICE-ROLE key here (server-only). NEVER expose this in
# browser code. The service-role key bypasses RLS.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
