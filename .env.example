# --- LLM (optional) ---
# Copy this file to `.env` in the project root (same folder as run.sh).
# The server reads `.env` only — NOT this file unless you copy it.
#
# If OPENAI_API_KEY is unset, agents use rule-based logic (no AI calls).
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# --- Google Geocoding (recommended for accurate routing) ---
# Enable "Geocoding API" in Google Cloud Console. GeoClusterAgent uses this
# to turn addresses like "90 Devon" into verified lat/lng + confidence scores.
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# Optional: West Island service area (defaults: Sainte-Anne depot, 45 km radius)
# SERVICE_AREA_LAT=45.4030
# SERVICE_AREA_LNG=-73.9470
# SERVICE_AREA_RADIUS_KM=45

# --- Supabase (optional) ---
# Dashboard → Project Settings → API → Project URL + service_role key
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt-here
